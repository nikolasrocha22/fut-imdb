# ─── Configurações do Banco de Dados (PostgreSQL / Neon) ───────────────────
# O app usa PostgreSQL em produção. Para desenvolvimento local você também pode
# usar PostgreSQL local ou uma instância dev do Neon.
DATABASE_URL="postgresql://usuario:senha@ep-host-db.neon.tech/futnota?sslmode=require"

# ─── Cache / Pub-Sub (Redis / Upstash) ───────────────────────────────────────
# O app usa Redis para comunicação SSE em tempo real. Em desenvolvimento local,
# se não houver um Redis rodando, o servidor cai para um fallback em memória automaticamente.
REDIS_URL="redis://default:sua_senha@host.upstash.io:6379"

# ─── API-Football (RapidAPI) ────────────────────────────────────────────────
# Obtenha uma chave em: https://rapidapi.com/api-sports/api/api-football
# O plano gratuito oferece 100 requisições por dia.
RAPID_API_KEY="sua-chave-rapidapi-aqui"
RAPID_API_HOST="api-football-v1.p.rapidapi.com"

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Obtenha sua chave de API gratuita em: https://aistudio.google.com/apikey
# Utilizado para gerar comentários e análises táticas em tempo real.
GEMINI_API_KEY="sua-chave-gemini-aqui"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
JWT_SECRET="insira-um-segredo-longo-e-seguro-aqui"

# URL do frontend para habilitar CORS (ex: Vercel)
FRONTEND_URL="https://seu-frontend.vercel.app"
